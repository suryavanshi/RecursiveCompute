{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recursive Compute Agentic Coding Trace",
  "type": "object",
  "required": ["trace_name", "model", "hardware", "requests"],
  "additionalProperties": false,
  "properties": {
    "trace_name": { "type": "string" },
    "description": { "type": "string" },
    "model": {
      "type": "object",
      "required": ["layers", "hidden_size", "num_q_heads", "num_kv_heads", "head_dim", "weight_bytes_per_token", "decode_ops_per_token", "prefill_ops_per_token"],
      "additionalProperties": false,
      "properties": {
        "layers": { "type": "integer", "minimum": 1 },
        "hidden_size": { "type": "integer", "minimum": 1 },
        "num_q_heads": { "type": "integer", "minimum": 1 },
        "num_kv_heads": { "type": "integer", "minimum": 1 },
        "head_dim": { "type": "integer", "minimum": 1 },
        "kv_bytes_per_element": { "type": "number", "minimum": 0, "default": 1 },
        "weight_bytes_per_token": { "type": "number", "minimum": 0 },
        "decode_ops_per_token": { "type": "number", "minimum": 0 },
        "prefill_ops_per_token": { "type": "number", "minimum": 0 }
      }
    },
    "hardware": {
      "type": "object",
      "required": ["remote_kv_bandwidth_bytes_s", "prefill_ops_s", "decode_ops_s", "collective_latency_s", "kv_local_hit_rate", "kv_remote_hit_rate"],
      "anyOf": [
        { "required": ["local_dram_bandwidth_bytes_s"] },
        { "required": ["local_hbm_bandwidth_bytes_s"] }
      ],
      "additionalProperties": false,
      "properties": {
        "local_dram_bandwidth_bytes_s": { "type": "number", "exclusiveMinimum": 0 },
        "local_hbm_bandwidth_bytes_s": { "type": "number", "exclusiveMinimum": 0, "deprecated": true },
        "remote_kv_bandwidth_bytes_s": { "type": "number", "exclusiveMinimum": 0 },
        "prefill_ops_s": { "type": "number", "exclusiveMinimum": 0 },
        "decode_ops_s": { "type": "number", "exclusiveMinimum": 0 },
        "collective_latency_s": { "type": "number", "minimum": 0 },
        "kv_local_hit_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "kv_remote_hit_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "requests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["request_id", "prefix_tokens", "reused_prefix_tokens", "new_prefill_tokens", "output_tokens"],
        "additionalProperties": false,
        "properties": {
          "request_id": { "type": "string" },
          "tenant_id": { "type": "string" },
          "locality_domain": { "type": "string" },
          "priority": { "type": "integer", "minimum": 0, "default": 0 },
          "prefix_tokens": { "type": "integer", "minimum": 0 },
          "reused_prefix_tokens": { "type": "integer", "minimum": 0 },
          "new_prefill_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
